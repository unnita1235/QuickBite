# Database Configuration (PostgreSQL via Neon)
DATABASE_URL=postgresql://user:password@host.neon.tech/database_name?sslmode=require
# Optional: increase if your hosted DB has cold-start latency
DB_CONNECTION_TIMEOUT_MS=10000

# JWT Configuration
JWT_SECRET=your_super_secure_random_string_here_min_32_chars_long

# Application Configuration
NODE_ENV=development
PORT=5000

# CORS Configuration (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:9002,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
